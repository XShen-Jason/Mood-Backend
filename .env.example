# ── Server ──────────────────────────────────────────────────────────────
PORT=3000

# ── Admin Auth ──────────────────────────────────────────────────────────
# Must match the secret stored on the Cloudflare Worker (not used by Worker anymore)
ADMIN_KEY=change-me-before-deploy

# ── Cloudflare Account ──────────────────────────────────────────────────
CF_ACCOUNT_ID=your-account-id
CF_API_TOKEN=your-api-token

# ── Cloudflare KV ───────────────────────────────────────────────────────
CF_KV_NAMESPACE_ID=your-kv-namespace-id

# ── Cloudflare R2 (S3-compatible) ───────────────────────────────────────
CF_R2_BUCKET=your-bucket-name
CF_R2_ACCESS_KEY_ID=your-r2-access-key-id
CF_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
CF_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ── Cloudflare Cache Purge ──────────────────────────────────────────────
CF_ZONE_ID=your-zone-id

# ── Supabase (not yet active — for future user auth & data storage) ─────
SUPABASE_URL=https://djcfqtrbfjaykdyperpf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
